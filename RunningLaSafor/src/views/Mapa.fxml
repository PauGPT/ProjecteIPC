<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MapaController">
   <children>
      <HBox alignment="CENTER">
         <children>
            <Button fx:id="btnAddMap" mnemonicParsing="false" prefHeight="45.0" prefWidth="300.0" text="+ Afegir mapa">
               <font>
                  <Font size="19.0" />
               </font>
            </Button>
         </children>
         <VBox.margin>
            <Insets bottom="20.0" top="20.0" />
         </VBox.margin>
      </HBox>
      <TableView fx:id="mapsTableView" prefHeight="294.0" prefWidth="447.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="regionCol" prefWidth="90.0" text="Regió" />
            <TableColumn fx:id="latMinCol" prefWidth="75.0" text="Lat. mín" />
            <TableColumn fx:id="latMaxCol" prefWidth="75.0" text="Lat. màx" />
            <TableColumn fx:id="lonMinCol" prefWidth="75.0" text="Lon. mín" />
            <TableColumn fx:id="lonMaxCol" prefWidth="75.0" text="Lon. màx" />
            <TableColumn fx:id="deleteColumn" prefWidth="75.0" styleClass="columna-centrada" />
        </columns>
         <VBox.margin>
            <Insets bottom="20.0" left="25.0" right="25.0" />
         </VBox.margin>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="900.0" spacing="15.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.historialDeSesiones">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Historial de Sessions de l'Usuari">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <TableView fx:id="sesionesTableView" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="fechaInicioCol" minWidth="140.0" prefWidth="-1.0" styleClass="columna-centrada" text="Inici" />
          <TableColumn fx:id="fechaFinCol" minWidth="140.0" prefWidth="-1.0" styleClass="columna-centrada" text="Fi" />
          <TableColumn fx:id="duracionCol" minWidth="90.0" prefWidth="-1.0" styleClass="columna-centrada" text="Duració (min)" />
          <TableColumn fx:id="importadasCol" minWidth="100.0" prefWidth="-1.0" styleClass="columna-centrada" text="Act. Importades" />
          <TableColumn fx:id="vistasCol" minWidth="90.0" prefWidth="-1.0" styleClass="columna-centrada" text="Act. Vistes" />
          <TableColumn fx:id="anotacionesCol" minWidth="110.0" prefWidth="-1.0" styleClass="columna-centrada" text="Anotacions creades" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <VBox prefWidth="100.0">
         <children>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Totals Acumulats:">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <HBox alignment="BOTTOM_LEFT" spacing="25.0">
               <children>
                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label style="-fx-text-fill: #7f8c8d;" text="Temps Total:" />
                        <Label fx:id="lblTotalTiempo" style="-fx-font-weight: bold; -fx-text-fill: #2980b9;" text="0 min" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label style="-fx-text-fill: #7f8c8d;" text="Importades:" />
                        <Label fx:id="lblTotalImportadas" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" text="0" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label style="-fx-text-fill: #7f8c8d;" text="Vistes:" />
                        <Label fx:id="lblTotalVistas" style="-fx-font-weight: bold; -fx-text-fill: #f39c12;" text="0" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label style="-fx-text-fill: #7f8c8d;" text="Anotacions:" />
                        <Label fx:id="lblTotalAnotaciones" style="-fx-font-weight: bold; -fx-text-fill: #8e44ad;" text="0" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
